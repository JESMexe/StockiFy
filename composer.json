{
  "require": {
    "vlucas/phpdotenv": "^5.6",
    "google/apiclient": "^2.15.0",
    "phpmailer/phpmailer": "^6.9.1",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-fileinfo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src\\"
    },
    "files": [
      "src/helpers/auth_helper.php"
